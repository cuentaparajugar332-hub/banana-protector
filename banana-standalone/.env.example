# Discord Bot
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_id

# Bot -> API authentication (same on both sides)
BOT_API_KEY=any_random_long_string

# Public URL where the API is hosted (used in generated URLs)
API_BASE_URL=https://api.tudominio.com

# Internal URL the bot uses to talk to the API
API_URL=http://localhost:3000

# Optional: restrict access
ALLOWED_GUILD_IDS=123456789012345678
ALLOWED_USER_IDS=123456789012345678